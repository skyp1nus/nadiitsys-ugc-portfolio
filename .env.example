# JWT signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# bcryptjs hash of your admin password — generate with:
# bun -e "console.log(require('bcryptjs').hashSync('your_password', 12))"
# Never store the plaintext password here.
ADMIN_PASSWORD_HASH=

# Public site URL (canonical) — used by robots.txt + sitemap.xml
NEXT_PUBLIC_SITE_URL=https://nadiitsys.com

# Public R2 media base URL — used by lib/r2.ts publicUrl()
NEXT_PUBLIC_MEDIA_URL=https://media.nadiitsys.com
