# JWT signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# bcryptjs hash of your admin password — generate with:
# bun -e "console.log(require('bcryptjs').hashSync('your_password', 12))"
# Never store the plaintext password here.
ADMIN_PASSWORD_HASH=

# Fine-grained GitHub PAT with `contents: write` on this repo only.
# Scopes needed: Repository permissions → Contents: Read and write
GH_TOKEN=

# GitHub repository owner (username or org)
GH_OWNER=

# GitHub repository name
GH_REPO=

# Public base URL for Cloudflare R2 bucket (no trailing slash)
# Example: https://media.nadiitsys.com
NEXT_PUBLIC_R2_PUBLIC_URL=
