{
  "name": "nadiitsys-ugc-portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint",
    "build:worker": "opennextjs-cloudflare build",
    "deploy:dry": "wrangler deploy --dry-run --outdir=.open-next/dry-run",
    "test": "bun run check && bun run build && bun run build:worker && bun run deploy:dry",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "db:types": "wrangler types",
    "db:schema": "wrangler d1 execute nadiitsys --remote --file=db/schema.sql",
    "db:seed": "wrangler d1 execute nadiitsys --remote --file=db/seed.sql",
    "db:local-reset": "wrangler d1 execute nadiitsys --local --file=db/schema.sql && wrangler d1 execute nadiitsys --local --file=db/seed.sql",
    "secrets:list": "wrangler secret list"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.84.1"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
